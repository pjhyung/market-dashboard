{# templates/daily.html.j2 #}
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ date }} 시장 전황 — Korea Market Command</title>
<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0F172A; --card: #1E293B; --border: #334155;
    --text: #F1F5F9; --muted: #64748B; --sub: #94A3B8;
    --up: #22C55E; --down: #EF4444;
  }
  body { background: var(--bg); color: var(--text); font-family: 'Pretendard', sans-serif; }
  header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 40px; border-bottom: 1px solid var(--border);
    background: linear-gradient(135deg, #0F172A 0%, #1a1f35 100%);
  }
  .logo { font-size: 18px; font-weight: 700; letter-spacing: 2px; }
  .logo span { color: #60A5FA; }
  .nav-date { display: flex; align-items: center; gap: 16px; }
  .nav-date a { color: var(--sub); text-decoration: none; font-size: 13px; padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; }
  .nav-date a:hover { border-color: #60A5FA; color: #60A5FA; }
  .date-title { font-size: 18px; font-weight: 600; }
  .back-btn { color: #60A5FA; text-decoration: none; font-size: 14px; padding: 8px 16px; border: 1px solid #60A5FA; border-radius: 8px; }
  .back-btn:hover { background: rgba(96,165,250,0.1); }
  main { padding: 32px 40px; max-width: 1400px; margin: 0 auto; }
  .toggle-bar { display: flex; gap: 8px; margin-bottom: 28px; }
  .toggle-btn {
    padding: 8px 24px; border-radius: 8px; border: 1px solid var(--border);
    background: var(--card); color: var(--sub); cursor: pointer;
    font-family: 'Pretendard', sans-serif; font-size: 14px; font-weight: 500;
    transition: all 0.2s;
  }
  .toggle-btn.active { background: #1D4ED8; border-color: #60A5FA; color: white; }
  .toggle-btn:hover:not(.active) { border-color: #60A5FA; }
  .section-title { font-size: 18px; font-weight: 700; margin-bottom: 20px; }
  .market-summary {
    background: linear-gradient(135deg, #1E293B 0%, #162032 100%);
    border: 1px solid var(--border); border-left: 3px solid #60A5FA;
    border-radius: 14px; padding: 24px 28px; margin-bottom: 36px;
  }
  .market-summary .section-title { margin-bottom: 12px; }
  .summary-text { color: var(--sub); line-height: 1.8; font-size: 14px; }
  .sectors-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 40px; }
  .sector-card {
    background: var(--card); border: 1px solid var(--border); border-radius: 14px;
    padding: 20px; transition: border-color 0.2s;
  }
  .sector-card:hover { border-color: #3D4F6B; }
  .sector-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
  .sector-rank { font-size: 11px; color: var(--muted); font-weight: 600; letter-spacing: 1px; }
  .sector-name { font-size: 18px; font-weight: 700; margin: 2px 0; }
  .sector-etf { font-size: 12px; color: var(--sub); margin-top: 2px; }
  .sector-right { text-align: right; }
  .change-pct { font-size: 24px; font-weight: 700; }
  .change-up { color: var(--up); }
  .change-down { color: var(--down); }
  .badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; margin-top: 6px;
  }
  .badge-golden { background: rgba(34,197,94,0.15); color: #22C55E; border: 1px solid rgba(34,197,94,0.3); }
  .badge-dead { background: rgba(239,68,68,0.15); color: #EF4444; border: 1px solid rgba(239,68,68,0.3); }
  .badge-hot { background: rgba(249,115,22,0.15); color: #F97316; border: 1px solid rgba(249,115,22,0.3); }
  .badge-cold { background: rgba(96,165,250,0.15); color: #60A5FA; border: 1px solid rgba(96,165,250,0.3); }
  .badge-up { background: rgba(34,197,94,0.1); color: #4ADE80; border: 1px solid rgba(34,197,94,0.2); }
  .badge-down { background: rgba(239,68,68,0.1); color: #F87171; border: 1px solid rgba(239,68,68,0.2); }
  .badge-neutral { background: rgba(148,163,184,0.1); color: var(--sub); border: 1px solid var(--border); }
  .indicators-row { display: flex; gap: 20px; margin: 12px 0; flex-wrap: wrap; }
  .indicator { display: flex; flex-direction: column; gap: 3px; }
  .ind-label { font-size: 10px; color: var(--muted); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
  .ind-value { font-size: 14px; font-weight: 600; color: var(--text); }
  .rsi-wrap { display: flex; flex-direction: column; gap: 3px; }
  .rsi-bar { width: 80px; height: 4px; background: var(--border); border-radius: 2px; }
  .rsi-fill { height: 100%; border-radius: 2px; }
  .divider { border: none; border-top: 1px solid var(--border); margin: 14px 0; }
  .top5-label { font-size: 11px; color: var(--muted); font-weight: 700; letter-spacing: 1px; margin-bottom: 8px; text-transform: uppercase; }
  .top5-table { width: 100%; border-collapse: collapse; }
  .top5-table td { padding: 5px 4px; font-size: 13px; }
  .top5-table td:first-child { color: var(--muted); width: 20px; font-size: 11px; }
  .top5-table td:nth-child(2) { color: var(--text); }
  .top5-table td:last-child { text-align: right; font-weight: 600; }
  .top5-table tr { border-bottom: 1px solid #1a2234; }
  .ai-box {
    background: rgba(96,165,250,0.05); border-left: 3px solid #60A5FA;
    border-radius: 0 8px 8px 0; padding: 12px 16px; margin-top: 12px;
    font-size: 13px; color: var(--sub); line-height: 1.7;
  }
  footer { text-align: center; padding: 24px; color: var(--muted); font-size: 12px; border-top: 1px solid var(--border); margin-top: 20px; }
  @media (max-width: 900px) {
    .sectors-grid { grid-template-columns: 1fr; }
    main { padding: 20px 16px; }
    header { padding: 16px 20px; flex-wrap: wrap; gap: 12px; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">KOREA MARKET <span>COMMAND</span></div>
  <div class="nav-date">
    {% if prev_date %}<a href="{{ prev_date }}.html">&#9664; {{ prev_date }}</a>{% endif %}
    <div class="date-title">{{ date }}</div>
    {% if next_date %}<a href="{{ next_date }}.html">{{ next_date }} &#9654;</a>{% endif %}
  </div>
  <a href="index.html" class="back-btn">&#8592; 달력</a>
</header>

<main>
  <div class="toggle-bar">
    <button class="toggle-btn active" onclick="setMode('daily', this)">일간</button>
    <button class="toggle-btn" onclick="setMode('weekly', this)">주간</button>
    <button class="toggle-btn" onclick="setMode('monthly', this)">월간</button>
  </div>

  <div class="market-summary">
    <div class="section-title">🤖 오늘의 시장 종합 분석</div>
    <div class="summary-text">{{ market_summary }}</div>
  </div>

  <div class="section-title">🏆 주도 섹터 TOP {{ sectors_data | length }}</div>
  <div class="sectors-grid" id="sectors-grid"></div>
</main>

<footer>Korea Market Command &middot; {{ date }} &middot; pykrx + Claude AI</footer>

<script>
const SECTORS = {{ sectors_data | tojson }};
let currentMode = "daily";

function setMode(mode, btn) {
  currentMode = mode;
  document.querySelectorAll(".toggle-btn").forEach(function(b) { b.classList.remove("active"); });
  btn.classList.add("active");
  renderSectors();
}

function renderSectors() {
  const grid = document.getElementById("sectors-grid");
  grid.innerHTML = "";

  SECTORS.forEach(function(s, idx) {
    const change = s.change_pct || 0;
    const changeClass = change >= 0 ? "change-up" : "change-down";
    const changeText = (change >= 0 ? "+" : "") + change.toFixed(2) + "%";
    const badge = s.signal_badge || {label: "중립", emoji: "➡", cls: "badge-neutral"};
    const top5 = (s.top5 && s.top5[currentMode]) ? s.top5[currentMode] : [];
    const rsi = s.rsi || 50;
    const rsiColor = rsi > 70 ? "#F97316" : rsi < 30 ? "#60A5FA" : "#22C55E";
    const rsiWidth = Math.min(100, Math.max(0, rsi));

    const card = document.createElement("div");
    card.className = "sector-card";
    card.style.borderTop = "3px solid " + (s.color || "#60A5FA");

    // Header
    const header = document.createElement("div");
    header.className = "sector-header";

    const left = document.createElement("div");
    const rank = document.createElement("div");
    rank.className = "sector-rank";
    rank.textContent = "#" + (idx + 1);
    const name = document.createElement("div");
    name.className = "sector-name";
    name.style.color = s.color || "#60A5FA";
    name.textContent = s.name || "";
    const etf = document.createElement("div");
    etf.className = "sector-etf";
    etf.textContent = s.etf_name || "";
    left.appendChild(rank); left.appendChild(name); left.appendChild(etf);

    const right = document.createElement("div");
    right.className = "sector-right";
    const changePct = document.createElement("div");
    changePct.className = "change-pct " + changeClass;
    changePct.textContent = changeText;
    const badgeEl = document.createElement("div");
    badgeEl.className = "badge " + (badge.cls || "badge-neutral");
    badgeEl.textContent = (badge.emoji || "") + " " + (badge.label || "");
    right.appendChild(changePct); right.appendChild(badgeEl);

    header.appendChild(left); header.appendChild(right);
    card.appendChild(header);

    // Indicators
    const indicators = document.createElement("div");
    indicators.className = "indicators-row";

    // RSI
    const rsiInd = document.createElement("div");
    rsiInd.className = "indicator rsi-wrap";
    const rsiLabel = document.createElement("div");
    rsiLabel.className = "ind-label"; rsiLabel.textContent = "RSI";
    const rsiVal = document.createElement("div");
    rsiVal.className = "ind-value"; rsiVal.textContent = rsi.toFixed(1);
    const rsiBarWrap = document.createElement("div");
    rsiBarWrap.className = "rsi-bar";
    const rsiFill = document.createElement("div");
    rsiFill.className = "rsi-fill";
    rsiFill.style.width = rsiWidth + "%";
    rsiFill.style.background = rsiColor;
    rsiBarWrap.appendChild(rsiFill);
    rsiInd.appendChild(rsiLabel); rsiInd.appendChild(rsiVal); rsiInd.appendChild(rsiBarWrap);

    // Volume
    const volInd = document.createElement("div");
    volInd.className = "indicator";
    const volLabel = document.createElement("div");
    volLabel.className = "ind-label"; volLabel.textContent = "거래량";
    const volVal = document.createElement("div");
    volVal.className = "ind-value";
    volVal.textContent = (s.volume_ratio || 1).toFixed(1) + "x";
    volInd.appendChild(volLabel); volInd.appendChild(volVal);

    // MA
    const maInd = document.createElement("div");
    maInd.className = "indicator";
    const maLabel = document.createElement("div");
    maLabel.className = "ind-label"; maLabel.textContent = "MA5/MA20";
    const maVal = document.createElement("div");
    maVal.className = "ind-value";
    maVal.style.fontSize = "12px";
    const ma5 = s.ma5 ? s.ma5.toFixed(0) : "-";
    const ma20 = s.ma20 ? s.ma20.toFixed(0) : "-";
    maVal.textContent = ma5 + " / " + ma20;
    maInd.appendChild(maLabel); maInd.appendChild(maVal);

    indicators.appendChild(rsiInd);
    indicators.appendChild(volInd);
    indicators.appendChild(maInd);
    card.appendChild(indicators);

    // Divider
    const divider = document.createElement("hr");
    divider.className = "divider";
    card.appendChild(divider);

    // TOP 5
    const top5Label = document.createElement("div");
    top5Label.className = "top5-label";
    const modeLabel = currentMode === "daily" ? "일간" : currentMode === "weekly" ? "주간" : "월간";
    top5Label.textContent = "종목 TOP 5 · " + modeLabel;
    card.appendChild(top5Label);

    const table = document.createElement("table");
    table.className = "top5-table";
    top5.forEach(function(stock, i) {
      const tr = document.createElement("tr");
      const td1 = document.createElement("td"); td1.textContent = i + 1;
      const td2 = document.createElement("td"); td2.textContent = stock.name || "";
      const td3 = document.createElement("td");
      const ret = stock.return_pct || 0;
      td3.textContent = (ret >= 0 ? "+" : "") + ret.toFixed(2) + "%";
      td3.style.color = ret >= 0 ? "var(--up)" : "var(--down)";
      tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3);
      table.appendChild(tr);
    });
    card.appendChild(table);

    // AI comment
    if (s.ai_comment) {
      const aiBox = document.createElement("div");
      aiBox.className = "ai-box";
      aiBox.textContent = s.ai_comment;
      card.appendChild(aiBox);
    }

    grid.appendChild(card);
  });
}

renderSectors();
</script>

</body>
</html>
